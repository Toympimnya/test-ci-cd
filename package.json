{
  "name": "laba6-ci-cd-tests",
  "version": "1.0.0",
  "description": "Laboratory work #6: CI/CD for complex automated tests",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "npm run test:unit",
    "test:unit": "jest --config=jest.config.allure.js",
    "test:api": "cucumber-js --config cucumber.js",
    "test:ui": "playwright test",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.53.0",
    "allure-commandline": "^2.29.0",
    "allure-cucumberjs": "^3.0.0",
    "allure-jest": "^3.0.0",
    "allure-playwright": "^3.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "wait-on": "^8.0.1"
  }
}
